# ─── Required ───────────────────────────────────────────────
DATABASE_URL=postgresql://username:password@host:5432/dbname

# ─── Anti-Bot Fallback APIs (Bypass Cloudflare) ───────────────
# Primary Anti-Bot API (ZenRows)
ZENROWS_API_KEY=your_zenrows_api_key_here

# Fallback Anti-Bot API (ScraperAPI)
SCRAPERAPI_KEY=your_scraperapi_key_here

# ─── Optional (Better poster + details ke liye) ──────────────
# TMDB free key: https://www.themoviedb.org/settings/api
TMDB_API_KEY=your_tmdb_api_key_here

# OMDB free key: https://www.omdbapi.com/apikey.aspx
OMDB_API_KEY=your_omdb_api_key_here
